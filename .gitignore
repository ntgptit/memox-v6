# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Local Node dependencies for the Flutter Web parity harness.
/tool/parity/node_modules/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated code (build_runner: riverpod, freezed, json_serializable, etc.)
# Regenerate locally with: dart run build_runner build
*.g.dart
*.freezed.dart
*.gr.dart
*.config.dart
*.mocks.dart
*.gen.dart
*.pb.dart
*.pbenum.dart
*.pbjson.dart
*.pbserver.dart

# Generated localization (flutter gen-l10n output; regenerated on `flutter pub get`)
/lib/l10n/generated/

# Design-kit scratch uploads (pasted screenshots; canonical font lives in fonts/)
docs/design/**/uploads/

# Design-kit QA screenshot artifacts (golden/parity shots, audit sheets, evidence).
# Heavy reference images regenerated by the kit's own tooling; not needed to build.
docs/design/**/shots/*.png
docs/design/**/_sheets/*.png
docs/design/**/evidence/*.png

