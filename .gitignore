# design-sync helper output (regenerated diff/push batches)
tools/design-sync/out/

# transient golden-failure dumps
test/**/failures/

# dart compile js byproducts of web/drift_worker.dart (the .js itself is committed)
web/drift_worker.js.deps
web/drift_worker.js.map
