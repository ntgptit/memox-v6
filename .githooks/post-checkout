#!/usr/bin/env bash
#
# Regenerate localizations after switching branches (or on clone) so the
# generated AppLocalizations matches the branch's ARB files.
#
# Args: $1 = previous HEAD, $2 = new HEAD, $3 = branch-checkout flag (1) vs
# file-checkout (0). Skip file checkouts to avoid needless work.
#
[ "$3" = "1" ] || exit 0

. "$(dirname "$0")/gen-l10n.sh"
regen_l10n
