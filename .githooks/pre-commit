#!/usr/bin/env bash
#
# Canonical MemoX verification entry (pre-commit).
# Emergency bypass (use sparingly):  git commit --no-verify
#
set -e

VERIFY="tool/verify/run.mjs"

if [ ! -f "$VERIFY" ]; then
  echo "verify: missing $VERIFY" >&2
  exit 1
fi

echo "verify: running MemoX quick gate..."
node "$VERIFY" --quick
