# Normalize line endings: Git stores text with LF, checks out per OS.
* text=auto eol=lf

# Explicit text files (source & config)
*.dart      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.swift     text eol=lf
*.h         text eol=lf
*.cc        text eol=lf
*.cpp       text eol=lf
*.m         text eol=lf
*.mm        text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.cmake     text eol=lf
*.plist     text eol=lf
*.pbxproj   text eol=lf
*.entitlements text eol=lf
*.xcconfig  text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.metadata   text eol=lf

# Windows-specific scripts keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets (never normalize or diff)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.svg       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.jar       binary
*.keystore  binary
*.jks       binary
*.p12       binary
*.so        binary
*.dylib     binary
*.dll       binary

# Lockfiles: text but do not report language stats
pubspec.lock text eol=lf linguist-generated
