-- Schema v1 — content table group (WBS 4.2 child A).
-- Contract: docs/database/schema-v1.md. SQL-first by owner directive:
-- all DDL lives in .drift files, never Dart Table classes.

-- Convention: every *_at column stores a UTC epoch-millisecond
-- timestamp. UI converts to the device timezone at render time;
-- local-day business rules use explicit local_date + timezone_id
-- columns instead (see progress.drift).

CREATE TABLE language_pairs (
  id TEXT NOT NULL PRIMARY KEY,
  learning_language_code TEXT NOT NULL,
  native_language_code TEXT NOT NULL,
  normalized_pair_key TEXT NOT NULL UNIQUE,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

CREATE TABLE decks (
  id TEXT NOT NULL PRIMARY KEY,
  language_pair_id TEXT NOT NULL REFERENCES language_pairs (id),
  parent_id TEXT REFERENCES decks (id),
  name TEXT NOT NULL,
  normalized_name TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

-- Sibling-name uniqueness with a nullable parent: one partial index per
-- root/child case (an expression index over IFNULL would hide the rule).
CREATE UNIQUE INDEX idx_decks_root_sibling_name ON decks (
  language_pair_id,
  normalized_name
) WHERE parent_id IS NULL;

CREATE UNIQUE INDEX idx_decks_child_sibling_name ON decks (
  parent_id,
  normalized_name
) WHERE parent_id IS NOT NULL;

CREATE TABLE flashcards (
  id TEXT NOT NULL PRIMARY KEY,
  deck_id TEXT NOT NULL REFERENCES decks (id),
  term TEXT NOT NULL,
  primary_meaning TEXT NOT NULL,
  content_version INTEGER NOT NULL DEFAULT 1,
  is_hidden INTEGER NOT NULL DEFAULT 0 CHECK (is_hidden IN (0, 1)),
  deleted_at INTEGER,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

CREATE INDEX idx_flashcards_deck ON flashcards (deck_id);

CREATE TABLE flashcard_translations (
  id TEXT NOT NULL PRIMARY KEY,
  card_id TEXT NOT NULL REFERENCES flashcards (id) ON DELETE CASCADE,
  language_code TEXT NOT NULL,
  translation_text TEXT NOT NULL,
  display_order INTEGER NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  UNIQUE (card_id, language_code, display_order)
);

CREATE TABLE tags (
  id TEXT NOT NULL PRIMARY KEY,
  name TEXT NOT NULL,
  normalized_name TEXT NOT NULL UNIQUE,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

CREATE TABLE flashcard_tags (
  card_id TEXT NOT NULL REFERENCES flashcards (id) ON DELETE CASCADE,
  tag_id TEXT NOT NULL REFERENCES tags (id) ON DELETE CASCADE,
  created_at INTEGER NOT NULL,
  PRIMARY KEY (card_id, tag_id)
);

-- Asset/provider metadata only; player state belongs to Audio Playback.
CREATE TABLE card_audio_refs (
  id TEXT NOT NULL PRIMARY KEY,
  card_id TEXT NOT NULL REFERENCES flashcards (id) ON DELETE CASCADE,
  language_code TEXT NOT NULL,
  asset_id TEXT NOT NULL,
  provider TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

CREATE INDEX idx_card_audio_refs_card ON card_audio_refs (card_id);
