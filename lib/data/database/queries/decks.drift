import '../tables/content.drift';

-- Deck aggregate queries (WBS 4.4A). Rename/move/delete are explicit
-- UPDATE/DELETE statements so the 4.3 exclusivity and cycle triggers
-- guard every path.

insertDeck:
INSERT INTO decks (
  id, language_pair_id, parent_id, name, normalized_name, created_at,
  updated_at
) VALUES (
  :id, :languagePairId, :parentId, :name, :normalizedName, :createdAt,
  :updatedAt
);

findDeckById:
SELECT * FROM decks WHERE id = :id;

watchRootDecks:
SELECT * FROM decks
WHERE language_pair_id = :languagePairId AND parent_id IS NULL
ORDER BY normalized_name, id;

-- Root decks with their direct card count and study-status counters (kit
-- deck-card meta line). Counts exclude soft-deleted cards; due/new also
-- exclude hidden cards to match the study-scope semantics (pageDueProgress).
-- `due` = a card whose progress is scheduled at or before :nowUtc; `new` =
-- a card that has never been studied (no progress row). Nested-deck totals
-- arrive with the deck-detail scope (subtree counts via countSubtreeCards).
watchRootDeckSummaries:
SELECT d.*,
  COUNT(DISTINCT CASE WHEN f.deleted_at IS NULL THEN f.id END) AS card_count,
  COUNT(DISTINCT CASE
    WHEN f.deleted_at IS NULL AND f.is_hidden = 0
      AND learning_progress.due_at IS NOT NULL
      AND learning_progress.due_at <= CAST(:nowUtc AS INTEGER)
      THEN f.id END) AS due_count,
  COUNT(DISTINCT CASE
    WHEN f.deleted_at IS NULL AND f.is_hidden = 0
      AND learning_progress.id IS NULL THEN f.id END) AS new_count
FROM decks d
LEFT JOIN flashcards f ON f.deck_id = d.id
LEFT JOIN learning_progress ON learning_progress.card_id = f.id
WHERE d.language_pair_id = :languagePairId AND d.parent_id IS NULL
GROUP BY d.id
ORDER BY d.normalized_name, d.id;

watchChildDecks:
SELECT * FROM decks WHERE parent_id = :parentId
ORDER BY normalized_name, id;

renameDeck:
UPDATE decks SET name = :name, normalized_name = :normalizedName,
  updated_at = :updatedAt
WHERE id = :id;

moveDeck:
UPDATE decks SET parent_id = :parentId, updated_at = :updatedAt
WHERE id = :id;

deleteDeck:
DELETE FROM decks WHERE id = :id;

countChildDecks:
SELECT COUNT(*) AS child_count FROM decks WHERE parent_id = :parentId;

updateDeckDescription:
UPDATE decks SET description = :description, updated_at = :updatedAt
WHERE id = :id;

countDecksForLanguagePair:
SELECT COUNT(*) AS deck_count FROM decks
WHERE language_pair_id = :languagePairId;

countSubtreeCards:
WITH RECURSIVE subtree (id) AS (
  SELECT :deckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT COUNT(*) AS card_count FROM flashcards
WHERE deck_id IN (SELECT id FROM subtree) AND deleted_at IS NULL;

-- Nested decks below a deck (all descendants, excluding the deck itself) — the
-- delete/reset impact summary (delete-deck.md §4). A descendant is any deck
-- whose parent is somewhere in the subtree.
countSubtreeDecks:
WITH RECURSIVE subtree (id) AS (
  SELECT :deckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT COUNT(*) AS deck_count FROM decks
WHERE parent_id IN (SELECT id FROM subtree);
