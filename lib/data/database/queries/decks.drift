import '../tables/content.drift';

-- Deck aggregate queries (WBS 4.4A). Rename/move/delete are explicit
-- UPDATE/DELETE statements so the 4.3 exclusivity and cycle triggers
-- guard every path.

insertDeck:
INSERT INTO decks (
  id, language_pair_id, parent_id, name, normalized_name, created_at,
  updated_at
) VALUES (
  :id, :languagePairId, :parentId, :name, :normalizedName, :createdAt,
  :updatedAt
);

findDeckById:
SELECT * FROM decks WHERE id = :id;

watchRootDecks:
SELECT * FROM decks
WHERE language_pair_id = :languagePairId AND parent_id IS NULL
ORDER BY normalized_name, id;

-- Root decks with their direct card count and study-status counters (kit
-- deck-card meta line). Counts exclude soft-deleted cards; due/new also
-- exclude hidden cards to match the study-scope semantics (pageDueProgress).
-- `due` = a card whose progress is scheduled at or before :nowUtc; `new` =
-- a card that has never been studied (no progress row). Nested-deck totals
-- arrive with the deck-detail scope (subtree counts via countSubtreeCards).
watchRootDeckSummaries:
SELECT d.*,
  COUNT(DISTINCT CASE WHEN f.deleted_at IS NULL THEN f.id END) AS card_count,
  COUNT(DISTINCT CASE
    WHEN f.deleted_at IS NULL AND f.is_hidden = 0
      AND learning_progress.due_at IS NOT NULL
      AND learning_progress.due_at <= CAST(:nowUtc AS INTEGER)
      THEN f.id END) AS due_count,
  COUNT(DISTINCT CASE
    WHEN f.deleted_at IS NULL AND f.is_hidden = 0
      AND learning_progress.id IS NULL THEN f.id END) AS new_count
FROM decks d
LEFT JOIN flashcards f ON f.deck_id = d.id
LEFT JOIN learning_progress ON learning_progress.card_id = f.id
WHERE d.language_pair_id = :languagePairId AND d.parent_id IS NULL
GROUP BY d.id
ORDER BY d.normalized_name, d.id;

watchChildDecks:
SELECT * FROM decks WHERE parent_id = :parentId
ORDER BY normalized_name, id;

renameDeck:
UPDATE decks SET name = :name, normalized_name = :normalizedName,
  updated_at = :updatedAt
WHERE id = :id;

moveDeck:
UPDATE decks SET parent_id = :parentId, updated_at = :updatedAt
WHERE id = :id;

deleteDeck:
DELETE FROM decks WHERE id = :id;

countChildDecks:
SELECT COUNT(*) AS child_count FROM decks WHERE parent_id = :parentId;

updateDeckDescription:
UPDATE decks SET description = :description, updated_at = :updatedAt
WHERE id = :id;

countDecksForLanguagePair:
SELECT COUNT(*) AS deck_count FROM decks
WHERE language_pair_id = :languagePairId;

countSubtreeCards:
WITH RECURSIVE subtree (id) AS (
  SELECT :deckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT COUNT(*) AS card_count FROM flashcards
WHERE deck_id IN (SELECT id FROM subtree) AND deleted_at IS NULL;

-- Nested decks below a deck (all descendants, excluding the deck itself) — the
-- delete/reset impact summary (delete-deck.md §4). A descendant is any deck
-- whose parent is somewhere in the subtree.
countSubtreeDecks:
WITH RECURSIVE subtree (id) AS (
  SELECT :deckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT COUNT(*) AS deck_count FROM decks
WHERE parent_id IN (SELECT id FROM subtree);

-- The ancestor chain of a deck (root → … → the deck itself) — the breadcrumb
-- path (WBS 6.2). `depth` counts up from the deck to the root, so ORDER BY
-- depth DESC yields the root first and the deck itself last.
deckAncestors:
WITH RECURSIVE chain (id, language_pair_id, parent_id, name, normalized_name,
  description, created_at, updated_at, depth) AS (
  SELECT id, language_pair_id, parent_id, name, normalized_name, description,
    created_at, updated_at, 0 FROM decks WHERE id = :deckId
  UNION ALL
  SELECT d.id, d.language_pair_id, d.parent_id, d.name, d.normalized_name,
    d.description, d.created_at, d.updated_at, chain.depth + 1
  FROM decks d INNER JOIN chain ON d.id = chain.parent_id
)
SELECT id, language_pair_id, parent_id, name, normalized_name, description,
  created_at, updated_at FROM chain ORDER BY depth DESC;

-- Valid move destinations for :movingDeckId (WBS 6.2 reparent). Every deck in
-- the pair that is NOT inside the moving deck's own subtree (moving into a
-- descendant would cycle), holds no direct active cards (deck exclusivity 4.3
-- forbids a deck owning both cards and child decks), and is not the deck's
-- current parent (a no-op move). Ordered by name for the picker.
moveDestinationDecks:
WITH RECURSIVE subtree (id) AS (
  SELECT :movingDeckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT d.* FROM decks d
WHERE d.language_pair_id = :languagePairId
  AND d.id NOT IN (SELECT id FROM subtree)
  AND d.id IS NOT (SELECT parent_id FROM decks WHERE id = :movingDeckId)
  AND NOT EXISTS (
    SELECT 1 FROM flashcards f
    WHERE f.deck_id = d.id AND f.deleted_at IS NULL
  )
ORDER BY d.normalized_name, d.id;

-- Valid move targets for a card (WBS 6.5 move-flashcard). Every deck in the
-- pair that can hold cards — Empty or Leaf, i.e. it has no child decks (a deck
-- with children is a Parent and 4.3 exclusivity forbids it owning cards) —
-- excluding the card's current deck. Ordered by name for the picker.
cardMoveDestinationDecks:
SELECT d.* FROM decks d
WHERE d.language_pair_id = :languagePairId
  AND d.id != :sourceDeckId
  AND NOT EXISTS (SELECT 1 FROM decks child WHERE child.parent_id = d.id)
ORDER BY d.normalized_name, d.id;

-- The active card ids in a deck's whole subtree — the reset-progress scope
-- (reset-deck-progress.md); Leaf = direct cards, Parent = descendant cards.
subtreeCardIds:
WITH RECURSIVE subtree (id) AS (
  SELECT :deckId
  UNION ALL
  SELECT d.id FROM decks d INNER JOIN subtree s ON d.parent_id = s.id
)
SELECT id FROM flashcards
WHERE deck_id IN (SELECT id FROM subtree) AND deleted_at IS NULL;
