import '../tables/progress.drift';

-- Preference store queries (WBS 4.4B). Values are versioned JSON; the
-- invalid-payload fallback is mapper-layer read behavior, not SQL.

upsertPreference:
INSERT INTO preferences (pref_key, value_json, value_schema_version, updated_at)
VALUES (:prefKey, :valueJson, :valueSchemaVersion, :updatedAt)
ON CONFLICT (pref_key) DO UPDATE SET
  value_json = excluded.value_json,
  value_schema_version = excluded.value_schema_version,
  updated_at = excluded.updated_at;

findPreference:
SELECT * FROM preferences WHERE pref_key = :prefKey;

watchPreference:
SELECT * FROM preferences WHERE pref_key = :prefKey;

deletePreference:
DELETE FROM preferences WHERE pref_key = :prefKey;
