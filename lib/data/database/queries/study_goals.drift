import '../tables/progress.drift';

-- Study Goal aggregate queries (WBS 4.4B): goal configuration plus the
-- per-local-day progress bucket. Contribution idempotency rides the
-- session-finalize exactly-once contract; the day upsert here is the
-- mechanical write it uses.

insertGoal:
INSERT INTO daily_goals (
  id, is_enabled, target_card_count, effective_from_local_date,
  timezone_id, created_at, updated_at
) VALUES (
  :id, :isEnabled, :targetCardCount, :effectiveFromLocalDate,
  :timezoneId, :createdAt, :updatedAt
);

findLatestGoal:
SELECT * FROM daily_goals
ORDER BY effective_from_local_date DESC, created_at DESC
LIMIT 1;

updateGoal:
UPDATE daily_goals SET
  is_enabled = :isEnabled,
  target_card_count = :targetCardCount,
  updated_at = :updatedAt
WHERE id = :id;

upsertDayProgress:
INSERT INTO goal_day_progress (
  id, local_date, timezone_id, goal_id, qualified_card_count,
  target_snapshot, is_met, created_at, updated_at
) VALUES (
  :id, :localDate, :timezoneId, :goalId, :qualifiedCardCount,
  :targetSnapshot, :isMet, :createdAt, :updatedAt
)
ON CONFLICT (local_date) DO UPDATE SET
  qualified_card_count = excluded.qualified_card_count,
  is_met = excluded.is_met,
  updated_at = excluded.updated_at;

findDayProgress:
SELECT * FROM goal_day_progress WHERE local_date = :localDate;

watchDayProgress:
SELECT * FROM goal_day_progress WHERE local_date = :localDate;
